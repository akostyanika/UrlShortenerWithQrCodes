{
    "name": "urlshortener/backend",
    "description": "URL Shortening Service Backend API",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "yiisoft/yii2": "~2.0.49",
        "yiisoft/yii2-bootstrap5": "^3.0.0",
        "endroid/qr-code": "^5.0",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "config": {
        "platform": {
            "php": "8.0"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.packagist.org",
            "canonical": true
        }
    ],
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "app\\tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
